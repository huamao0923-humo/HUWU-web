# ================================
# 華宇資訊科技官網 環境變數設定
# ================================
# 複製此檔案為 .env.local 並填入實際值

# ------- Payload CMS -------
# 必填：至少 32 字元的隨機字串（可用 openssl rand -hex 32 產生）
PAYLOAD_SECRET=your-super-secret-payload-secret-at-least-32-chars

# ------- 資料庫 -------
# PostgreSQL（Railway / Neon / Supabase）
DATABASE_URI=postgresql://user:password@host:5432/database

# ------- Next.js -------
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ------- Email（Resend）-------
# 申請自 https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_NOTIFY_EMAIL=info@yourdomain.com

# ------- 後台管理密碼 -------
ADMIN_PASSWORD=your-admin-password

# ------- Google Analytics -------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ------- UploadThing（檔案上傳，可選）-------
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxx
